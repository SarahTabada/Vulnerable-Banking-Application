from flask import Flask
from flask_sqlalchemy import SQLAlchemy

db = SQLAlchemy()

def register_blueprint_with_api(app, bp, prefix=""):
    app.register_blueprint(bp, url_prefix=f"/api{prefix}")

def create_app():
    app = Flask(__name__)
    app.config.from_object("app.config.Config")
    db.init_app(app)

    with app.app_context():
        print("augudfabfuiao")
        db.create_all()

    from app.routes.testingConnection import testing_connection_bp
    register_blueprint_with_api(app, testing_connection_bp)

    from app.routes.auth import auth_bp
    register_blueprint_with_api(app, auth_bp, "/auth")

    from app.routes.accounts import accounts_bp
    register_blueprint_with_api(app, accounts_bp)

    from app.routes.transactions import transactions_bp
    register_blueprint_with_api(app, transactions_bp)

    from app.routes.user import user_bp
    register_blueprint_with_api(app, user_bp)

    from app.routes.transfers import transfers_bp
    register_blueprint_with_api(app, transfers_bp, "/transfers")

    from app.routes.billing import billing_bp
    register_blueprint_with_api(app, billing_bp)

    return app

