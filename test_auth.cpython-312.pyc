# models.py
## OLD DB NOT USED
from sqlalchemy import Column, Integer, String, Date, Enum, Float, ForeignKey, CheckConstraint, TIMESTAMP, BigInteger
from sqlalchemy.orm import declarative_base, relationship
import uuid
from datetime import datetime

Base = declarative_base()

def generate_uuid():
    return str(uuid.uuid4())

class Customer(Base):
    __tablename__ = "customer"

    customer_id = Column(String(36), primary_key=True, default=generate_uuid)
    password = Column(String(100), nullable=False)
    name = Column(String(200), nullable=False)
    street = Column(String(200))
    city = Column(String(100))
    state = Column(String(50))
    phone = Column(String(30))
    email = Column(String(200), unique=True)
    date_of_birth = Column(Date)

    def __repr__(self):
        return f"<Customer {self.customer_id} {self.name}>"


class Account(Base):
    __tablename__ = "account"

    account_id = Column(Integer, primary_key=True, autoincrement=True)
    customer_id = Column(String(36), ForeignKey("customer.customer_id", onupdate="CASCADE", ondelete="RESTRICT"), nullable=False)
    branch_id = Column(Integer, ForeignKey("branch.branch_id", onupdate="CASCADE", ondelete="RESTRICT"), nullable=False)
    account_type = Column(Enum("checking", "savings", "money_market", "cd", name="account_type_enum"), nullable=False)
    balance = Column(Float(18, 2), nullable=False, default=0)
    opening_date = Column(Date, nullable=False)
    status = Column(Enum("active", "closed", "frozen", "dormant", name="account_status_enum"), nullable=False)

    # Relationships
    customer = relationship("Customer", backref="accounts")
    branch = relationship("Branch", backref="accounts")
    transactions = relationship("TransactionLog", back_populates="account", cascade="all, delete-orphan")

    __table_args__ = (
        CheckConstraint("balance >= 0", name="check_account_balance_nonnegative"),
    )

    def __repr__(self):
        return f"<Account {self.account_id} {self.account_type} {self.balance}>"


class Loan(Base):
    __tablename__ = "loan"

    loan_id = Column(Integer, primary_key=True, autoincrement=True)
    customer_id = Column(String(36), ForeignKey("customer.customer_id", onupdate="CASCADE", ondelete="RESTRICT"), nullable=False)
    branch_id = Column(Integer, ForeignKey("branch.branch_id", onupdate="CASCADE", ondelete="RESTRICT"), nullable=False)
    amount = Column(Float(18, 2), nullable=False)
    interest_rate = Column(Float(6, 3), nullable=False)
    start_date = Column(Date, nullable=False)
    end_date = Column(Date)
    status = Column(Enum("active", "closed", "defaulted", "pending", name="loan_status_enum"), nullable=False)

    # Relationships
    customer = relationship("Customer", backref="loans")
    branch = relationship("Branch", backref="loans")

    __table_args__ = (
        CheckConstraint("amount > 0", name="check_loan_amount_positive"),
        CheckConstraint("interest_rate >= 0", name="check_loan_interest_nonnegative"),
    )

    def __repr__(self):
        return f"<Loan {self.loan_id} {self.amount} {self.status}>"


class TransactionLog(Base):
    __tablename__ = "transaction_log"

    transaction_id = Column(BigInteger, primary_key=True, autoincrement=True)
    account_id = Column(Integer, ForeignKey("account.account_id", onupdate="CASCADE", ondelete="CASCADE"), nullable=False)
    transaction_type = Column(Enum("deposit", "withdrawal", "transfer_in", "transfer_out", "fee", "interest", name="transaction_type_enum"), nullable=False)
    amount = Column(Float(18, 2), nullable=False)
    transaction_date = Column(TIMESTAMP, nullable=False, default=datetime.utcnow)
    description = Column(String(500))

    # Relationship
    account = relationship("Account", back_populates="transactions")

    __table_args__ = (
        CheckConstraint("amount > 0", name="check_transaction_amount_positive"),
    )

    def __repr__(self):
        return f"<TransactionLog {self.transaction_id} {self.transaction_type} {self.amount}>"
    

