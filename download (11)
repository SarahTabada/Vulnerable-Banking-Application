## Cookie Details
JWT_SECRET = os.getenv("JWT_SECRET", "supersecret")
JWT_ALGO = os.getenv("JWT_ALGO", "HS256")
COOKIE_NAME = os.getenv("COOKIE_NAME", "auth_token")
INSECURE = os.getenv("INSECURE", "false").lower() in ("1", "true", "yes", "on")

def create_jwt_for_user(user: User) -> str:
    """
    Create a JWT containing user_id and first_name.
    Expires in 30 minutes.
    """
    userJWT = UserJWT(user_id=user.id)
    payload = userJWT.dict()

    token = jwt.encode(payload, JWT_SECRET, algorithm=JWT_ALGO)

    # PyJWT returns string in PyJWT 2.x
    return token


def decode_jwt_to_user(token: str) -> UserJWT:
    """Decode JWT payload into a UserSchema object."""
    data = jwt.decode(token, JWT_SECRET, algorithms=[JWT_ALGO])
    return UserJWT(user_id=data["user_id"])

def verify_jwt(token: str):
    """Return decoded payload or raise error."""
    return jwt.decode(token, JWT_SECRET, algorithms=[JWT_ALGO])

##Password Details
def verify_password(plain: str, hashed: str) -> bool:
    """Return True if password matches bcrypt hash."""
    return bcrypt.checkpw(plain.encode("utf-8"), hashed.encode("utf-8"))

def hash_password(password: str) -> str:
    """Hash a new password."""
    return bcrypt.hashpw(password.encode("utf-8"), bcrypt.gensalt()).decode("utf-8")

## Query and Conversion

def authenticate_user_secure(credentials: LoginRequest):
    """
    Returns User object if credentials are valid, otherwise None.
    """
    with get_db_session() as db:
        user = db.query(User).filter(User.username == credentials.username).first()

        if not user:
            return None

        if not verify_password(credentials.password, user.password):
            return None
        
        db.expunge(user)
        return user

def authenticate_user_insecure(credentials: LoginRequest):
    """
    INSECURE version.
    - Vulnerable to SQL injection
    - Still verifies bcrypt password
    """

    username = credentials.username
    password = credentials.password

    with get_insecure_raw_connection() as raw:
        cur = raw.cursor()
        sql = f"SELECT * FROM users WHERE username = '{username}';"
        print("INSECURE SQL:", sql)
        cur.execute(sql)
        result = cur.fetchone()
        # If attacker used multiple statements, flush through them:
        while cur.nextset() is not None:
            pass
        
        cur.close()

    if not result:
        return None
    
    user_id = result[0]
    print(user_id)

    with get_db_session() as db:
        if not user_id:
            return None
        
        # Result is a row tuple → convert to ORM Customer object
        user = db.query(User).get(user_id)  # returns first matching user

        # bcrypt verification still happens
        if bcrypt.checkpw(password.encode(), user.password.encode()):
            db.expunge(user)
            return user
        return None
    
def authenticate_user(credentials: LoginRequest):
    if(INSECURE):
        return authenticate_user_insecure(credentials)
    else:
        return authenticate_user_secure(credentials)
    